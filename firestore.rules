rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Multiplayer matches — any authenticated user can read/write
    // (client-trust model; seat validation is in application code)
    match /pisti-matches/{matchId} {
      allow read, write: if request.auth != null;
    }

    // User profiles and friends sub-collection
    match /pisti-users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /friends/{friendUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Head-to-head rival records (pairId = minUid_maxUid)
    match /pisti-friend-rivals/{pairId} {
      // resource is null when the doc does not exist yet (first match / list probe)
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.uids);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.uids;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.uids;
      allow delete: if false;
    }

    // In-app friend challenges
    // NOTE: list queries cannot use OR (fromUid || toUid) — Firestore rejects the query.
    // Incoming listener filters toUid == me; get/update still allow either party.
    match /pisti-game-requests/{requestId} {
      allow get: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow list: if request.auth != null
        && resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.status == 'pending';
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.toUid
            || request.auth.uid == resource.data.fromUid);
      allow delete: if false;
    }
  }
}
